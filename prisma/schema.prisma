generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Người dùng — cá nhân hóa phân tích + đăng nhập email
model User {
  id                  String               @id @default(uuid()) @db.Uuid
  /// Email đăng nhập (chuẩn hóa lowercase), null = legacy / tài khoản cũ không auth
  email               String?              @unique @map("email")
  passwordHash        String?              @map("password_hash")
  resetToken          String?              @map("reset_token")
  resetTokenExpiry    DateTime?            @map("reset_token_expiry")
  name                String
  skinType            SkinType             @map("skin_type")
  /// Ví dụ: "Mụn, lão hóa, thâm nám" (chuỗi tự do hoặc CSV tùy client)
  skinConcerns        String               @map("skin_concerns")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  recommendedRoutines RecommendedRoutine[]
  skinEntries         SkinEntry[]
  skinImages          SkinImage[]
  routines            SkincareRoutine[]

  @@index([resetToken])
  @@map("users")
}

/// Thư viện sản phẩm (cache INCI / hoạt chất)
model Product {
  id              String          @id @default(uuid()) @db.Uuid
  brandName       String          @map("brand_name")
  productName     String          @map("product_name")
  ingredientsList String          @map("ingredients_list")
  isVerified      Boolean         @default(false) @map("is_verified")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  routineDetails  RoutineDetail[]

  @@index([brandName, productName])
  @@map("products")
}

/// Routine gắn với user
model SkincareRoutine {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  routineName String            @map("routine_name")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  analyses    AnalysisHistory[]
  details     RoutineDetail[]
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("skincare_routines")
}

/// Từng bước trong routine: sản phẩm, buổi, thứ tự layering
model RoutineDetail {
  id         String          @id @default(uuid()) @db.Uuid
  routineId  String          @map("routine_id") @db.Uuid
  productId  String?         @map("product_id") @db.Uuid
  timeOfDay  TimeOfDay       @map("time_of_day")
  orderIndex Int             @map("order_index")
  product    Product?        @relation(fields: [productId], references: [id])
  routine    SkincareRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([routineId, timeOfDay, orderIndex])
  @@map("routine_details")
}

/// Lịch sử chấm điểm AI — tránh gọi lại token
model AnalysisHistory {
  id                String          @id @default(uuid()) @db.Uuid
  routineId         String          @map("routine_id") @db.Uuid
  overallScore      Int             @map("overall_score")
  /// JSON: ví dụ [{"pair":"Retinol-AHA","level":"high"}]
  conflicts         Json            @default("[]")
  aiRecommendations String          @map("ai_recommendations")
  createdAt         DateTime        @default(now()) @map("created_at")
  routine           SkincareRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([routineId, createdAt])
  @@map("analysis_history")
}

/// Nhật ký da — ảnh Blob (trước bắt buộc; trái/phải tuỳ chọn) + phân tích JSON (Vision)
model SkinEntry {
  id             String   @id @default(cuid())
  userId         String   @map("user_id") @db.Uuid
  imageUrlFront  String   @map("image_url_front")
  imageUrlLeft   String?  @map("image_url_left")
  imageUrlRight  String?  @map("image_url_right")
  analysisResult Json     @map("analysis_result")
  userNote       String?  @map("user_note")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("skin_entries")
}

/// Gợi ý routine theo ngân sách sau phân tích ảnh da (Gemini Vision + text)
model RecommendedRoutine {
  id            String   @id @default(cuid())
  userId        String   @map("user_id") @db.Uuid
  imageUrlFront String   @map("image_url_front")
  imageUrlLeft  String   @map("image_url_left")
  imageUrlRight String   @map("image_url_right")
  /// JSON: loại da, điểm số, mô tả mụn/lỗ chân lông…
  faceAnalysis  Json     @map("face_analysis")
  /// JSON: gói BUDGET hoặc 3 tầng TIET_KIEM / HIEU_QUA / CAO_CAP
  routineResult Json     @map("routine_result")
  /// "BUDGET" | "AUTO"
  mode          String   @map("mode")
  budgetVnd     Int?     @map("budget_vnd")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("recommended_routines")
}

/// Lưu URL ảnh upload lên Blob ngay sau upload để tránh mất URL trên iOS
model SkinImage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  scope     String
  url       String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("skin_images")
}

enum SkinType {
  OILY
  DRY
  COMBINATION
  SENSITIVE
}

/// Sáng / Tối
enum TimeOfDay {
  AM
  PM
}
