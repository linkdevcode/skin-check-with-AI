# Vercel Postgres — copy to .env.local for local dev
# Lấy connection string từ Vercel Dashboard → Storage → Postgres → .env.local
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Google Gemini — AI Studio https://aistudio.google.com/apikey
# (Biến dự phòng: GOOGLE_GENERATIVE_AI_API_KEY)
GEMINI_API_KEY=""

# URL công khai (SEO / OG). Ví dụ: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth — bắt buộc trên production (chuỗi ngẫu nhiên ≥32 ký tự)
# Tạo: openssl rand -base64 32
AUTH_SECRET=""

# (Tùy) Trùng NEXT_PUBLIC_APP_URL trên Vercel — dùng cho callback auth
AUTH_URL=""

# Vercel Blob — upload ảnh nhật ký da (token từ Vercel Dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=""

RESEND_API_KEY=""
# Ví dụ: "SkinCheck AI <onboarding@resend.dev>" hoặc domain đã xác minh
RESEND_FROM=""
